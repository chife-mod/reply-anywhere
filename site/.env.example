# Copy to `.env` for local dev. Real values are NOT committed.
# PUBLIC_* vars are exposed to the browser (read at build time by Astro).

# Cloudflare Turnstile — spam protection on the demo form.
#   site key  → PUBLIC_TURNSTILE_SITEKEY (client widget)
#   secret    → TURNSTILE_SECRET (server, set via `wrangler secret put TURNSTILE_SECRET`)
PUBLIC_TURNSTILE_SITEKEY=

# Cloudflare Web Analytics — privacy-first, zero-cookie, no client JS cost worth
# mentioning. Beacon token from the CF dashboard (Analytics → Web Analytics).
PUBLIC_CF_ANALYTICS_TOKEN=

# ─── Server-only (set via `wrangler secret put`, never committed) ───
# TURNSTILE_SECRET   — Turnstile secret key
# LEAD_WEBHOOK_URL   — where verified demo leads are delivered (SF HelpDesk endpoint)
