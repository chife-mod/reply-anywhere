{
  "name": "reply-anywhere-site",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "cf:dev": "astro build && wrangler dev",
    "deploy": "PREVIEW_NOINDEX=1 astro build && printf '\\n# preview gate — removed by deploy:live\\n/*\\n  X-Robots-Tag: noindex\\n' >> dist/_headers && wrangler deploy",
    "deploy:live": "astro build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "astro": "^6.4.6",
    "gsap": "^3.15.0"
  },
  "devDependencies": {
    "wrangler": "^4.24.4"
  }
}
