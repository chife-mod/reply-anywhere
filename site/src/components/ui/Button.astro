---
// THE button (Figma node 6:294 / 13:810 / 26:481). Three variants, exact tokens:
//  primary — bg --violet · p16 · r8 · Inter Medium 14 white · leading-none
//  dark    — bg --surface-tile (#111322), same metrics (CTA band, dark contexts)
//  icon    — 1px --violet border square · p11 · r8 · 24px icon slot (arrow companion)
interface Props {
  href: string;
  variant?: 'primary' | 'dark' | 'icon';
  label?: string; // text variants; icon variant uses slot for <Icon>
  class?: string;
}
const { href, variant = 'primary', label, class: cls } = Astro.props;
---

<a href={href} class:list={['btn', `btn--${variant}`, cls]}>
  {label}
  <slot />
</a>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* ONE height for EVERY button on the site — 48 (--sp-12, Figma 13:810
       «Book a demo»). Client 2026-07-21: hero/menu buttons rendered 48 (the
       icon variant's 11+24+11+2 stretched its flex row) while CTA-band and
       Compare rendered the padding-only 46 — a two-height fork. Height is
       owned HERE; sections must never re-declare it. */
    min-height: var(--sp-12);
    border-radius: var(--r-md);
    font-family: var(--font-sans);
    font-size: var(--fs-ui);
    font-weight: var(--fw-medium);
    line-height: 1;
    color: var(--text-hi);
    text-decoration: none;
    transition: filter var(--dur-fast) var(--ease-out);
  }
  .btn--primary {
    background: var(--violet);
    padding: var(--sp-4);
  }
  .btn--dark {
    background: var(--surface-tile);
    padding: var(--sp-4);
  }
  .btn--icon {
    border: 1px solid var(--violet);
    padding: 11px; /* 11 + 24 icon + 11 + 2 border = the same 48px, square */
  }
  .btn:hover { filter: brightness(1.12); }
  /* focus ring comes from the ONE global :focus-visible convention (global.css) */
</style>
