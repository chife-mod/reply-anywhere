---
// Compare — implemented 1:1 from Oleg's Claude Design file «Comparison Table.html»
// (project 9e24ba3d «Reply Anywhere comparison table», designed on the synced
// design-language bundle, imported 2026-07-21). Design decisions are the file's:
// eyebrow + one-line H2 with inline accent, $-tier in each vendor header,
// violet zebra rows, flat row list (no group headers), quantitative-first
// cells with big numbers, qualifier pills (Add-on / Q4), honest «no» in our
// own column, legend with real $ mappings. This build adds only what the
// design canvas has no context for: the fixed-menu sticky offset, #demo
// anchors, SVG marks as repo files, and the ≤946/≤760 adaptive.
// Data flags pending Vsevolod's sign-off are tracked in the session report
// (channel counts, «12 languages», gominga benchmarking cell, trial claim).
// Systemization pass (client 2026-07-21): section chrome = the SAME shared
// system as every other section — SectionHeading, THE Button, Features' head
// grid and paddings; sticky thead dropped (the table scrolls inside its own
// block — the floating menu made sticky read as broken layering).
import Icon from '../ui/Icon.astro';
import Button from '../ui/Button.astro';
import SectionHeading from '../ui/SectionHeading.astro';

// Client 2026-07-21: qualifier pills (Add-on / Q4) removed — canvas additions
// that were never in the task; cells are marks, numbers and $-tiers only.
type MarkCell = { mark: 'yes' | 'no'; label: string };
type NumCell = { num: string; unit?: string };
type Cell = MarkCell | NumCell;

const vendors = [
  { name: 'Sprinklr', sub: 'Enterprise CXM suite', tier: 5 },
  { name: 'Gominga', sub: 'Review management', tier: 3 },
  { name: 'Reply Anywhere', sub: 'Omnichannel · AI-first', tier: 2, us: true },
];

const rows: { title: string; sub: string; cells: [Cell, Cell, Cell] }[] = [
  {
    title: 'Connected channels',
    sub: 'Review sites, marketplaces & social inboxes in one place',
    cells: [{ num: '30', unit: '+' }, { num: '20', unit: '+' }, { num: '40', unit: '+' }],
  },
  {
    title: 'AI reply languages',
    sub: "Draft on-brand replies in the customer's language",
    cells: [{ num: '100', unit: '+' }, { num: '12' }, { num: '50', unit: '+' }],
  },
  {
    title: 'AI-drafted responses',
    sub: 'Context-aware draft ready before you open the thread',
    cells: [{ mark: 'yes', label: 'Yes' }, { mark: 'no', label: 'No' }, { mark: 'yes', label: 'Yes' }],
  },
  {
    title: 'Brand-tone tuning',
    sub: "Train the model on your voice, do's and don'ts",
    cells: [{ mark: 'yes', label: 'Yes' }, { mark: 'no', label: 'No' }, { mark: 'yes', label: 'Yes' }],
  },
  {
    title: 'Bulk one-click replies',
    sub: 'Approve and send drafts across dozens of reviews at once',
    cells: [{ mark: 'no', label: 'No' }, { mark: 'yes', label: 'Yes' }, { mark: 'yes', label: 'Yes' }],
  },
  {
    title: 'Sentiment analytics',
    sub: 'Track tone and themes across every channel',
    cells: [{ mark: 'yes', label: 'Yes' }, { mark: 'yes', label: 'Yes' }, { mark: 'yes', label: 'Yes' }],
  },
  {
    title: 'Competitor benchmarking',
    sub: 'Compare your ratings against rival locations & brands',
    cells: [{ mark: 'yes', label: 'Yes' }, { mark: 'no', label: 'No' }, { mark: 'no', label: 'No' }],
  },
  {
    title: 'Shared team inbox',
    sub: 'Assign, comment and resolve without leaving the thread',
    cells: [{ mark: 'yes', label: 'Yes' }, { mark: 'yes', label: 'Yes' }, { mark: 'yes', label: 'Yes' }],
  },
  {
    title: 'Self-serve setup',
    sub: 'No mandatory onboarding fee or sales call to start',
    cells: [{ mark: 'no', label: 'No' }, { mark: 'no', label: 'No' }, { mark: 'yes', label: 'Yes' }],
  },
];

const tierGlyphs = (tier: number) => ({ on: '$'.repeat(tier), off: '$'.repeat(5 - tier) });
const isMark = (c: Cell): c is MarkCell => 'mark' in c;
---

<section class="cmp-section" id="compare" aria-labelledby="cmp-title">
  <div class="cmp-wrap">
    <header class="cmp-head" id="cmp-title">
      <SectionHeading line1="The same job, done for" accent="a fraction of the price" align="left" />
      <p class="cmp-lead">
        Sprinklr and Gominga each do part of it well. Reply Anywhere unifies more channels and
        AI-drafted replies without the enterprise contract — and we mark where the others win.
      </p>
    </header>

    <table class="cmp-table">
      <caption>
        Feature comparison: Sprinklr vs Gominga vs Reply Anywhere across channels, AI replies,
        analytics, workflow and pricing.
      </caption>
      <colgroup>
        <col class="col-feature" />
        <col class="col-vendor" />
        <col class="col-vendor" />
        <col class="col-vendor" />
      </colgroup>
      <thead>
        <tr>
          <th scope="col" class="head-cell feature-head"></th>
          {vendors.map((v) => (
            <th scope="col" class:list={['head-cell', { 'ra-col': v.us }]}>
              <span class:list={['vendor-logo', { ra: v.us }]}><span>{v.name}</span></span>
              <div class="vendor-name">{v.sub}</div>
              <div class:list={['vendor-price', { 'ra-price': v.us }]}>
                <span aria-hidden="true">{tierGlyphs(v.tier).on}<span class="off">{tierGlyphs(v.tier).off}</span></span>
                <span class="sr-only">Price tier {v.tier} of 5</span>
              </div>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr class="feat">
            <th scope="row" class="feat-name">
              <div class="feat-title">{row.title}</div>
              <div class="feat-sub">{row.sub}</div>
            </th>
            {row.cells.map((cell, i) => (
              <td class:list={['val', { 'ra-col': i === 2 }]}>
                {isMark(cell) ? (
                  <span class="mark" role="img" aria-label={cell.label}>
                    <Icon
                      name={cell.mark === 'yes' ? (i === 2 ? 'compare/yes-us' : 'compare/yes') : 'compare/no'}
                      size={28}
                      alt=""
                    />
                  </span>
                ) : (
                  <>
                    <span class="num">{cell.num}</span>
                    {cell.unit && <span class="unit">{cell.unit}</span>}
                  </>
                )}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>

    <div class="cmp-cta-row">
      <Button href="#demo" label="Request a free demo" />
      <span class="cta-hint">14-day trial · no card · cancel anytime</span>
    </div>

    <div class="cmp-foot">
      <div class="legend">
        <span class="legend-item"><b aria-hidden="true">$$</b> Under $500/mo</span>
        <span class="legend-sep"></span>
        <span class="legend-item"><b aria-hidden="true">$$$</b> $500–2k/mo</span>
        <span class="legend-sep"></span>
        <span class="legend-item"><b aria-hidden="true">$$$$$</b> Enterprise / custom</span>
      </div>
      <p class="cmp-note">
        Price tiers from each vendor's published plans and public pricing pages, July 2026.
        Competitor capabilities reflect their standard tiers.
      </p>
    </div>
  </div>
</section>

<style>
  /* Section chrome = the Features pattern verbatim: same paddings, same
     head grid, same heading component, same lead measure and color. */
  .cmp-section {
    padding: var(--sp-10) var(--margin-desktop);
    scroll-margin-top: 96px; /* #compare anchor lands below the fixed menu */
  }
  .cmp-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
    max-width: var(--container);
    margin-inline: auto;
  }
  .cmp-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--sp-8);
  }
  .cmp-lead {
    width: 416px; /* Figma 24:992 — same measure as features__lead */
    flex-shrink: 0;
    font-size: var(--fs-lead);
    line-height: var(--lh-body);
    color: var(--text-body);
  }

  /* ── table shell ─────────────────────────────────────────── */
  .cmp-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    table-layout: fixed;
  }
  .cmp-table caption {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }
  .cmp-table col.col-feature { width: 34%; }
  .cmp-table col.col-vendor { width: 22%; }

  /* ── product header row (client 2026-07-21: NOT sticky — the table
     scrolls inside its own block; sticky under the floating menu islands
     produced a broken-looking double layer) ── */
  .head-cell {
    background: var(--bg);
    padding: var(--sp-6) var(--sp-5) var(--sp-5);
    text-align: center;
    vertical-align: top;
    border-bottom: 1px solid var(--border-line);
  }
  .head-cell.feature-head {
    text-align: left;
    vertical-align: bottom;
  }
  .vendor-logo {
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--sp-3);
  }
  .vendor-logo span {
    font-size: 22px; /* design literal — vendor wordmark row */
    font-weight: var(--fw-bold);
    letter-spacing: -0.01em;
    color: var(--text-hi);
  }
  .vendor-name {
    font-size: var(--fs-chip);
    color: var(--text-dim);
    margin-bottom: var(--sp-4);
    white-space: nowrap;
  }
  .vendor-price {
    font-size: var(--fs-card-title);
    font-weight: var(--fw-bold);
    letter-spacing: 0.06em;
    color: var(--text-body);
    font-variant-numeric: tabular-nums;
  }
  .vendor-price .off {
    color: var(--text-dim);
    opacity: 0.35;
  }

  /* ── highlighted RA column ───────────────────────────────── */
  .ra-col {
    background: var(--surface-pill-social);
    border-left: 1px solid var(--border-strong);
    border-right: 1px solid var(--border-strong);
  }
  thead .ra-col.head-cell {
    background: linear-gradient(180deg, rgba(171, 13, 255, 0.22), rgba(171, 13, 255, 0.1));
    border-top: 1px solid var(--border-strong);
    border-top-left-radius: var(--r-md);
    border-top-right-radius: var(--r-md);
    border-bottom-color: var(--border-strong);
  }
  .vendor-logo.ra span { color: var(--text-hi); }
  .ra-price { color: var(--text-hi); }

  /* ── feature rows: violet zebra (design: RA stripe rides along) ── */
  tbody tr.feat td,
  tbody tr.feat th {
    border-bottom: 1px solid var(--border-soft);
  }
  tbody tr.feat th.feat-name,
  tbody tr.feat td.val { background: transparent; }
  tbody tr.feat td.ra-col.val { background: rgba(171, 13, 255, 0.14); }
  tbody tr.feat:nth-of-type(even) th.feat-name,
  tbody tr.feat:nth-of-type(even) td.val { background: rgba(139, 118, 255, 0.055); }
  tbody tr.feat:nth-of-type(even) td.ra-col.val { background: rgba(171, 13, 255, 0.24); }

  th.feat-name {
    text-align: left;
    font-weight: var(--fw-regular);
    padding: var(--sp-45) var(--sp-4);
    vertical-align: top;
  }
  .feat-title {
    font-size: var(--fs-card-sub);
    font-weight: var(--fw-medium);
    color: var(--text-hi);
  }
  .feat-sub {
    margin-top: 3px;
    font-size: var(--fs-chip);
    line-height: 1.35; /* design literal */
    color: var(--text-dim);
    max-width: 34ch;
  }

  td.val {
    text-align: center;
    vertical-align: middle;
    padding: var(--sp-45) var(--sp-4);
    font-size: var(--fs-card-sub);
    color: var(--text-body);
    font-variant-numeric: tabular-nums;
  }
  td.val .num {
    font-size: var(--fs-card-title);
    font-weight: var(--fw-semibold);
    color: var(--text-hi);
    letter-spacing: -0.01em;
  }
  td.val .unit {
    font-size: var(--fs-chip);
    color: var(--text-dim);
  }
  td.ra-col.val .num { color: var(--violet-light); }

  .mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .mark :global(img) {
    width: 28px;
    height: 28px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── bottom rounding of RA column ────────────────────────── */
  tbody tr.feat:last-of-type td.ra-col {
    border-bottom: 1px solid var(--border-strong);
    border-bottom-left-radius: var(--r-md);
    border-bottom-right-radius: var(--r-md);
  }

  /* ── CTA + legend / footnote ─────────────────────────────── */
  .cmp-cta-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-3);
    margin-top: var(--sp-10);
  }
  .cta-hint {
    font-size: var(--fs-chip);
    color: var(--text-dim);
  }
  .cmp-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-6);
    margin-top: var(--sp-8);
    padding-top: var(--sp-5);
    font-size: var(--fs-chip);
    color: var(--text-dim);
  }
  .legend {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .legend-item b {
    color: var(--text-body);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.06em;
  }
  .legend-sep {
    width: 1px;
    height: 14px;
    background: var(--border-line);
  }
  .cmp-note {
    margin-left: auto;
    max-width: 44ch;
    text-align: right;
    line-height: 1.4;
  }

  /* ── Adaptive (the canvas is desktop-only; same degrade rules as the
     rest of the site: ≤946 burger zone, ≤760 phone compaction) ── */
  @media (max-width: 946px) {
    .cmp-head {
      flex-direction: column;
      align-items: flex-start;
    }
    .cmp-lead { width: auto; max-width: 549px; }
  }
  @media (max-width: 760px) {
    .head-cell,
    th.feat-name,
    td.val { padding: var(--sp-3) var(--sp-2); }
    .cmp-table col.col-feature { width: 30%; }
    .cmp-table col.col-vendor { width: auto; }
    .vendor-logo { height: auto; margin-bottom: var(--sp-2); }
    .vendor-logo span { font-size: var(--fs-chip); white-space: normal; }
    .vendor-name { display: none; }
    .vendor-price { font-size: var(--fs-ui); letter-spacing: 0; }
    .feat-sub { display: none; }
    .feat-title { font-size: var(--fs-ui); }
    td.val .num { font-size: var(--fs-lead); }
    .mark :global(img) { width: 24px; height: 24px; }
    .cmp-note {
      margin-left: 0;
      text-align: left;
      max-width: none;
    }
  }
</style>
